---
import { Image } from 'astro:assets';
import ofertaBanner from '../assets/ofertas/ofertabanner.webp';
import videoSrc from '../assets/videos/videofarmaonline.mp4';
import adheridoFTCheq from '../assets/adherido.webp';
---

<main>
    <section class="hero-cards">
        <a href="/ofertas" class="hero-banner-link">
            <Image
                src={ofertaBanner}
                alt="Farmacia La Estrella - Productos farmacéuticos y ofertas en Paraná, Entre Ríos"
                class="offer-banner"
                loading="eager"
                fetchpriority="high"
                sizes="(max-width: 768px) 95vw, 1220px"
            />
        </a>

        <a href="https://www.farmaonline.com/" class="hero-video-link" target="_blank" rel="noopener noreferrer" aria-label="Visitar Farmaonline.com">
            <video src={videoSrc} autoplay muted playsinline loop>
                Tu navegador no soporta el elemento de video.
            </video>
        </a>

        <a href="https://www.ftcheq.com.ar/" class="hero-ftcheq-link" target="_blank" rel="noopener noreferrer" aria-label="Comercio adherido a FTCheq">
            <Image src={adheridoFTCheq} alt="Comercio adherido a FTCheq" loading="lazy" />
        </a>

    </section>
</main>

<style>
    main {
        display: flex;
        flex-direction: column;
        text-align: center;
        color: var(--color-text);
        max-width: 1040px;
        margin: 40px auto;
        padding: 0 20px;
    }

    .hero-cards {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .hero-video-link, .hero-banner-link, .hero-ftcheq-link {
        display: block;
        overflow: hidden;
        border-radius: 25px;
        box-shadow: 0 4px 12px var(--color-shadow);
        border: 2px solid var(--color-primary-lighter);
        transition: all 0.3s ease;
    }

    .hero-video-link {
        aspect-ratio: 16 / 9;
    }

    .hero-video-link video {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .hero-banner-link img {
        width: 100%;
        height: auto;
        display: block;
    }

    .hero-ftcheq-link {
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .hero-ftcheq-link img {
        max-height: 180px;
        width: auto;
        object-fit: cover;
        display: block;
    }

    @media (hover: hover) {
        .hero-video-link:hover,
        .hero-banner-link:hover,
        .hero-ftcheq-link:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 20px var(--color-shadow-hover);
            border-color: var(--color-primary);
        }
    }

    @media (max-width: 768px) {
        main {
            padding: 0;
            margin: 20px auto 40px;
        }

        .hero-cards {
            max-width: 95%;
            margin: auto;
            gap: 15px;
        }

        .hero-video-link {
            aspect-ratio: 16 / 9;
        }

        .hero-ftcheq-link img {
            max-height: 60px;
        }
    }
</style>